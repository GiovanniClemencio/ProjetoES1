package Controller;

public class TesteConta
{
    public static void main(String[] args)
    {
        ControladorConta controlador = new ControladorConta();

        // Criando contas
        Conta conta1 = new Conta(1, "Luan", 1000.0);
        Conta conta2 = new Conta(2, "Maria", 2000.0);

        // Adicionando contas
        controlador.criarConta(conta1);
        controlador.criarConta(conta2);

        // Buscando conta
        Conta encontrada = controlador.buscarConta(1);

        if (encontrada != null)
        {
            System.out.println("Conta encontrada: " + encontrada.getCodConta());
        }
        else
        {
            System.out.println("Conta não encontrada");
        }

        // Removendo conta
        boolean removida = controlador.removerConta(1);

        if (removida)
        {
            System.out.println("Conta removida com sucesso");
        }
        else
        {
            System.out.println("Falha ao remover conta");
        }

        // Tentando buscar novamente
        Conta teste = controlador.buscarConta(1);

        if (teste == null)
        {
            System.out.println("Conta realmente removida");
        }
    }
}
